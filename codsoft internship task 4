import os
from datetime import datetime
tasks = []
def display_menu():
    """Display the main menu options"""
    print("\n" + "=" * 50)
    print("           TO-DO LIST MANAGER")
    print("=" * 50)
    print("1. View all tasks")
    print("2. Add a new task")
    print("3. Update a task")
    print("4. Mark task as complete")
    print("5. Delete a task")
    print("6. Search tasks")
    print("7. Exit")
    print("=" * 50)
def view_tasks():
    """Display all tasks with their status"""
    if not tasks:
        print("\n Your to-do list is empty!")
        return
    print("\n" + "-" * 50)
    print("                 YOUR TASKS")
    print("-" * 50)
    for i, task in enumerate(tasks, 1):
        status = " " if task['completed'] else "⭕"
        print(f"{i}. {status} {task['title']}")
        print(f"    Added: {task['date_added']}")
        if task['completed']:
            print(f"    Completed: {task['date_completed']}")
        if task['description']:
            print(f"    {task['description']}")
        print()
def add_task():
    """Add a new task to the list"""
    print("\n" + "-" * 50)
    print("              ADD NEW TASK")
    print("-" * 50)
    title = input("Enter task title: ").strip()
    if not title:
        print(" Error: Task title cannot be empty!")
        return
    description = input("Enter task description (optional): ").strip()
    now = datetime.now()
    current_time = now.strftime("%Y-%m-%d %H:%M")
    new_task = {
        'title': title,
        'description': description,
        'completed': False,
        'date_added': current_time,
        'date_completed': None
    }
    tasks.append(new_task)
    print(f"\n Task '{title}' added successfully!")
def update_task():
    """Update an existing task"""
    if not tasks:
        print("\n No tasks to update!")
        return
    view_tasks()
    try:
        task_num = int(input("\nEnter task number to update: "))
        if 1 <= task_num <= len(tasks):
            task = tasks[task_num - 1]        
            print(f"\nUpdating task: {task['title']}")
            print("1. Update title")
            print("2. Update description")
            print("3. Update both")       
            choice = input("Enter your choice (1-3): ")    
            if choice == '1':
                new_title = input("Enter new title: ").strip()
                if new_title:
                    task['title'] = new_title
                    print(" Task title updated!")       
            elif choice == '2':
                new_desc = input("Enter new description: ").strip()
                task['description'] = new_desc
                print(" Task description updated!")
            elif choice == '3':
                new_title = input("Enter new title: ").strip()
                new_desc = input("Enter new description: ").strip()
                if new_title:
                    task['title'] = new_title
                task['description'] = new_desc
                print(" Task updated successfully!")
            else:
                print(" Invalid choice!")
        else:
            print(" Invalid task number!")     
    except ValueError:
        print(" Please enter a valid number!")
def mark_complete():
    """Mark a task as complete"""
    if not tasks:
        print("\n No tasks to mark as complete!")
        return
    incomplete_tasks = [task for task in tasks if not task['completed']]
    
    if not incomplete_tasks:
        print("\n All tasks are completed! Great job!")
        return
    print("\n" + "-" * 50)
    print("         INCOMPLETE TASKS")
    print("-" * 50)
    for i, task in enumerate(incomplete_tasks, 1):
        print(f"{i}. ⭕ {task['title']}")
    try:
        task_num = int(input("\nEnter task number to mark as complete: "))
        if 1 <= task_num <= len(incomplete_tasks):
            task = incomplete_tasks[task_num - 1]
            for t in tasks:
                if t['title'] == task['title'] and not t['completed']:
                    t['completed'] = True
                    now = datetime.now()
                    t['date_completed'] = now.strftime("%Y-%m-%d %H:%M")
                    print(f"\n Task '{task['title']}' marked as complete!")
                    break
        else:
            print(" Invalid task number!") 
    except ValueError:
        print(" Please enter a valid number!")
def delete_task():
    """Delete a task from the list"""
    if not tasks:
        print("\n No tasks to delete!")
        return
    view_tasks()
    try:
        task_num = int(input("\nEnter task number to delete: "))
        if 1 <= task_num <= len(tasks):
            deleted_task = tasks.pop(task_num - 1)
            print(f"\n Task '{deleted_task['title']}' deleted successfully!")
        else:
            print(" Invalid task number!") 
    except ValueError:
        print(" Please enter a valid number!")
def search_tasks():
    """Search for tasks by keyword"""
    if not tasks:
        print("\n No tasks to search!")
        return
    keyword = input("\nEnter search keyword: ").strip().lower()
    if not keyword:
        print(" Please enter a search keyword!")
        return
    found_tasks = []
    for task in tasks:
        if (keyword in task['title'].lower() or 
            keyword in task['description'].lower()):
            found_tasks.append(task)
    if found_tasks:
        print("\n" + "-" * 50)
        print(f"         SEARCH RESULTS FOR '{keyword}'")
        print("-" * 50)
        for i, task in enumerate(found_tasks, 1):
            status = " " if task['completed'] else "⭕"
            print(f"{i}. {status} {task['title']}")
            if task['description']:
                print(f"    {task['description']}")
    else:
        print(f"\n No tasks found containing '{keyword}'")
def main():
    """Main program loop"""
    os.system('cls' if os.name == 'nt' else 'clear')
    print("=" * 50)
    print("     WELCOME TO TO-DO LIST MANAGER")
    print("=" * 50)
    print("Keep track of your tasks efficiently!")
    while True:
        display_menu()
        try:
            choice = input("\nEnter your choice (1-7): ")
            if choice == '1':
                view_tasks()
            elif choice == '2':
                add_task()
            elif choice == '3':
                update_task()
            elif choice == '4':
                mark_complete()
            elif choice == '5':
                delete_task()
            elif choice == '6':
                search_tasks()
            elif choice == '7':
                print("\n" + "=" * 50)
                print("     THANK YOU FOR USING TO-DO LIST MANAGER")
                print("            Have a productive day!")
                print("=" * 50)
                break
            else:
                print(" Invalid choice! Please enter a number between 1-7.")
        except KeyboardInterrupt:
            print("\n\n  Program interrupted. Exiting...")
            break
        except Exception as e:
            print(f"\n An error occurred: {e}")
